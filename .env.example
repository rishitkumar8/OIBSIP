# ─────────────────────────────────────────────────────────────────────────────
# Supabase — get these from your Supabase project settings → API
# ─────────────────────────────────────────────────────────────────────────────

# Project URL  (Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key  (Settings → API → Project API keys → anon public)
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service-role secret  (Settings → API → Project API keys → service_role)
# NEVER expose this to the browser — server-side only!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────────
# Razorpay — get these from the Razorpay dashboard
# Use TEST mode keys while developing; switch to LIVE keys for production.
# ─────────────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
